setLogLevel::{Int}->{Void}:(
    level: Ri

    innerCPP: "
        switch (level)
        {
            case 0:
                HC_APP.loglevel(crow::LogLevel::Debug);
                break;
            case 1:
                HC_APP.loglevel(crow::LogLevel::Info);
                break;
            case 2:
                HC_APP.loglevel(crow::LogLevel::Warning);
                break;
            case 3:
                HC_APP.loglevel(crow::LogLevel::Error);
                break;
            case 4:
                HC_APP.loglevel(crow::LogLevel::Critical);
                break;
            default:
                HC_APP.loglevel(crow::LogLevel::Warning);
                break;
        }
    "
)

get::{String,String}->{Void}:(
    path: Ri.0
    body: Ri.1

    innerCPP: "
        std::string p(
            reinterpret_cast<char const*>(path._data),
            path._size
        );

        std::string b(
            reinterpret_cast<char const*>(body._data),
            body._size
        );

        HC_APP.route_dynamic(p)
        ([b](const crow::request&)
        {
            crow::response r(200);
            r.set_header(\"Content-Type\", \"text/plain; charset=utf-8\");
            r.write(b);
            return r;
        });
    "
)

