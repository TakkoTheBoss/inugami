file::{String,String}->{Void}:(
    route: Ri.0
    filePath: Ri.1

    innerCPP: "
        std::string p(
            reinterpret_cast<char const*>(route._data),
            route._size
        );

        std::string fp(
            reinterpret_cast<char const*>(filePath._data),
            filePath._size
        );

        HC_APP.route_dynamic(p)
        ([fp](const crow::request&)
        {
            std::ifstream file(fp, std::ios::binary);
            if (!file.is_open())
            {
                return crow::response(404, \"file not found\");
            }

            std::string content(
                (std::istreambuf_iterator<char>(file)),
                std::istreambuf_iterator<char>()
            );

            crow::response r(200);
            r.write(content);
            return r;
        });
    "
)

